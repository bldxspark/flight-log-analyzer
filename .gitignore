.venv/
.env/
env/
venv/
ENV/
env.bak/
venv.bak/

# Exclude build and temporary directories
build/
dist/
downloads/
*.egg-info/
*.egg
*.egg
MANIFEST

# Exclude logs and reports
logs/
flight_reports/

# Exclude images
images/

# Distribution / packaging
.Python
develop-eggs/
parts/
sdist/
var/
wheels/

# PyInstaller
# Usually these files are written by a python script from a template
# before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

